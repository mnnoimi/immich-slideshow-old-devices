# ──────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────
IMMICH_URL=http://your-immich-server:2283
IMMICH_API_KEY=your_api_key_here

# ──────────────────────────────────────────────────────────
# Optional — all can also be overridden via URL parameters
# ──────────────────────────────────────────────────────────

# Album ID(s) to display — comma-separated for multiple albums
# URL param: ?album_id=id1,id2
ALBUM_ID=your_album_id

# Seconds each photo is displayed
# URL param: ?duration=10
CAROUSEL_DURATION=5

# Background colour (CSS colour name or hex)
# URL param: ?background=%23000000
CSS_BACKGROUND_COLOR=#000000

# Show photos in random order (true/false)
# URL param: ?random=true
RANDOM_ORDER=false

# iOS status bar style (default | black | black-translucent)
# URL param: ?status_bar=black-translucent
STATUS_BAR_STYLE=black-translucent

# Filter photos by orientation (all | landscape | portrait)
# URL param: ?orientation=landscape
IMAGES_ORIENTATION=all

# Crop images to fill the screen (true) or fit with letterbox bars (false)
# URL param: ?crop=true
CROP_TO_SCREEN=true

# Subtle Ken Burns zoom/pan motion on each photo (true/false)
# URL param: ?ken_burns=true
KEN_BURNS=true

# Display language for dates and day names (en | ar)
# URL param: ?locale=ar
LOCALE=ar
